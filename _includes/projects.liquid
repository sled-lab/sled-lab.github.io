<div class="col">
  {% if project.redirect %}
    {% assign project_url = project.redirect %}
  {% else %}
    {% assign project_url = project.url | relative_url %}
  {% endif %}
  {% assign project_link_enabled = true %}
  {% if project.link == false %}
    {% assign project_link_enabled = false %}
  {% endif %}
  <div class="card h-100 hoverable">
    {% if project_link_enabled %}
      <a href="{{ project_url }}">
    {% endif %}
    {% if project.img %}
      {%
        include figure.liquid
        loading="eager"
        path=project.img
        sizes = "250px"
        alt="project thumbnail"
        class="card-img-top z-depth-1"
      %}
    {% endif %}
    <div class="card-body person-heading">
      <h2 class="card-title">{{ project.title }}</h2>
    </div>
    {% if project_link_enabled %}
      </a>
    {% endif %}
    <div class="card-body person-details">
      <p class="card-text">{{ project.description }}</p>
      {% if project.email %}
        <p class="card-text">{{ project.email }}</p>
      {% endif %}
      {% if project.research %}
        <p class="card-text">{{ project.research }}</p>
      {% endif %}
      <div class="row ml-1 mr-1 p-0">
        {% if project.github %}
          <div class="github-icon">
            <div class="icon" data-toggle="tooltip" title="Code Repository">
              <a href="{{ project.github }}"><i class="fa-brands fa-github gh-icon"></i></a>
            </div>
            {% if project.github_stars %}
              <span class="stars" data-toggle="tooltip" title="GitHub Stars">
                <i class="fa-solid fa-star"></i>
                <span id="{{ project.github_stars }}-stars"></span>
              </span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>
